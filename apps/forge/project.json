{
  "name": "forge",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "drc",
  "sourceRoot": "apps/forge/src",
  "tags": ["scope:forge", "type:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/forge",
        "browser": "apps/forge/src/main.ts",
        "tsConfig": "apps/forge/tsconfig.app.json",
        "inlineStyleLanguage": "css",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/forge/public"
          }
        ],
        "styles": ["apps/forge/src/styles.css"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/forge/src/environments/environment.ts",
              "with": "apps/forge/src/environments/environment.development.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "forge:build:production"
        },
        "development": {
          "buildTarget": "forge:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {}
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "forge:build",
        "staticFilePath": "dist/apps/forge/browser",
        "spa": true
      }
    }
  },
  "schematics": {
    "@schematics/angular:component": {
      "style": "css",
      "type": "component",
      "changeDetection": "OnPush",
      "skipTests": true
    },
    "@schematics/angular:directive": {
      "type": "directive",
      "flat": true,
      "skipTests": true
    },
    "@schematics/angular:service": {
      "type": "service",
      "flat": true,
      "skipTests": true
    },
    "@schematics/angular:guard": {
      "typeSeparator": ".",
      "flat": true,
      "skipTests": true
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": ".",
      "flat": true,
      "skipTests": true
    },
    "@schematics/angular:pipe": {
      "typeSeparator": ".",
      "flat": true,
      "skipTests": true
    },
    "@schematics/angular:resolver": {
      "typeSeparator": ".",
      "flat": true,
      "skipTests": true
    }
  }
}
